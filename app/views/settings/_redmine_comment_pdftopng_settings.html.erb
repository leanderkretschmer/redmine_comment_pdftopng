<p>
  <label><%= l(:label_rcpp_enabled) %></label>
  <%= check_box_tag "settings[enabled]", "1", settings["enabled"].to_s == "1" %>
</p>

<p>
  <label><%= l(:label_rcpp_scope_mode) %></label>
  <%= select_tag "settings[scope_mode]", options_for_select([[l(:label_rcpp_scope_global), "global"], [l(:label_rcpp_scope_manual), "manual"]], settings["scope_mode"].presence || "global") %>
</p>

<% if (settings["scope_mode"].presence || "global") == "manual" %>
  <p>
    <label><%= l(:label_rcpp_project_identifiers) %></label>
    <%= text_field_tag "settings[project_identifiers]", settings["project_identifiers"].to_s, size: 80 %>
  </p>

  <p>
    <label><%= l(:label_rcpp_issue_ids) %></label>
    <%= text_field_tag "settings[issue_ids]", settings["issue_ids"].to_s, size: 80 %>
  </p>
<% end %>

<p>
  <label><%= l(:label_rcpp_render_mode) %></label>
  <%= select_tag "settings[render_mode]", options_for_select([[l(:label_rcpp_render_cover), "cover"], [l(:label_rcpp_render_all_pages), "all_pages"]], settings["render_mode"].presence || "cover") %>
</p>

<p>
  <label><%= l(:label_rcpp_thumbnail_max_px) %></label>
  <%= text_field_tag "settings[thumbnail_max_px]", settings["thumbnail_max_px"].to_s, size: 10 %>
</p>

<p>
  <label><%= l(:label_rcpp_page_max_px) %></label>
  <%= text_field_tag "settings[page_max_px]", settings["page_max_px"].to_s, size: 10 %>
</p>

<p>
  <label><%= l(:label_rcpp_png_description_template) %></label>
  <%= text_field_tag "settings[png_description_template]", settings["png_description_template"].to_s, size: 80 %>
</p>

<p>
  <label><%= l(:label_rcpp_pngquant_path) %></label>
  <%= text_field_tag "settings[pngquant_path]", settings["pngquant_path"].to_s, size: 80 %>
  <% cmd = RedmineCommentPdftopng::Settings.pngquant_path rescue "pngquant" %>
  <% version = RedmineCommentPdftopng::PdfConverter.pngquant_version rescue nil %>
  <% available = RedmineCommentPdftopng::PdfConverter.pngquant_available? rescue false %>
  <em><%= available ? "#{l(:text_rcpp_pngquant_found)} (#{cmd}#{version.present? ? ", #{version}" : ""})" : "#{l(:text_rcpp_pngquant_missing)} (#{cmd})" %></em>
</p>

<p>
  <%= button_tag l(:button_rcpp_render_missing),
                 type: "submit",
                 formaction: url_for(controller: "redmine_comment_pdftopng", action: "render_missing"),
                 formmethod: "post",
                 data: { confirm: l(:text_rcpp_render_missing_confirm) } %>
</p>

<fieldset class="box">
  <legend><%= l(:label_rcpp_conversion_log) %></legend>
  <% entries = RedmineCommentPdftopng::ConversionLog.entries(limit: 100) rescue [] %>
  <% if entries.any? %>
    <pre style="white-space: pre-wrap;"><%= entries.map { |e| "#{e[:at]} #{e[:message]}" }.join("\n") %></pre>
  <% else %>
    <em><%= l(:text_rcpp_conversion_log_empty) %></em>
  <% end %>
</fieldset>
