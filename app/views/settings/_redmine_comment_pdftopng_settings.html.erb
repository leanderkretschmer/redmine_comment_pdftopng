<p>
  <label><%= l(:label_rcpp_enabled) %></label>
  <%= check_box_tag "settings[enabled]", "1", settings["enabled"].to_s == "1" %>
</p>

<p>
  <label><%= l(:label_rcpp_scope_mode) %></label>
  <%= select_tag "settings[scope_mode]", options_for_select([[l(:label_rcpp_scope_all), "all"], [l(:label_rcpp_scope_projects), "projects"], [l(:label_rcpp_scope_issues), "issues"]], settings["scope_mode"].presence || "all") %>
</p>

<p>
  <label><%= l(:label_rcpp_project_ids) %></label>
  <% selected_project_ids = Array(settings["project_ids"]).map(&:to_i) %>
  <%= select_tag "settings[project_ids][]",
                 options_from_collection_for_select(Project.sorted.to_a, "id", "name", selected_project_ids),
                 multiple: true,
                 size: 10 %>
</p>

<p>
  <label><%= l(:label_rcpp_issue_ids) %></label>
  <%= text_field_tag "settings[issue_ids]", settings["issue_ids"].to_s, size: 80 %>
</p>

<p>
  <label><%= l(:label_rcpp_render_mode) %></label>
  <%= select_tag "settings[render_mode]", options_for_select([[l(:label_rcpp_render_cover), "cover"], [l(:label_rcpp_render_all_pages), "all_pages"]], settings["render_mode"].presence || "cover") %>
</p>

<p>
  <label><%= l(:label_rcpp_quality) %></label>
  <%= select_tag "settings[quality]", options_for_select([["low", "low"], ["medium", "medium"], ["high", "high"], ["original", "original"]], settings["quality"].presence || "medium") %>
</p>

<p>
  <label><%= l(:label_rcpp_tool) %></label>
  <%= select_tag "settings[tool]", options_for_select([["MiniMagick", "mini_magick"], ["HexaPDF", "hexa_pdf"]], settings["tool"].presence || "mini_magick") %>
</p>

<p>
  <label><%= l(:label_rcpp_thumbnail_max_px) %></label>
  <%= text_field_tag "settings[thumbnail_max_px]", settings["thumbnail_max_px"].to_s, size: 10 %>
</p>

<fieldset class="box">
  <legend><%= l(:label_rcpp_conversion_log) %></legend>
  <% begin %>
    <% logs = RedmineCommentPdftopng::ConversionLog.order(id: :desc).limit(50).to_a %>
    <% if logs.empty? %>
      <em><%= l(:label_rcpp_log_empty) %></em>
    <% else %>
      <div class="autoscroll">
        <table class="list">
          <thead>
            <tr>
              <th><%= l(:label_date) %></th>
              <th><%= l(:label_issue) %></th>
              <th><%= l(:label_attachment) %></th>
              <th><%= l(:label_rcpp_render_mode) %></th>
              <th><%= l(:label_rcpp_quality) %></th>
              <th><%= l(:label_rcpp_tool) %></th>
              <th><%= l(:field_status) %></th>
              <th><%= l(:label_rcpp_generated_images) %></th>
            </tr>
          </thead>
          <tbody>
            <% logs.each do |log| %>
              <tr class="<%= cycle('odd', 'even') %>">
                <td><%= format_time(log.created_at) %></td>
                <td>
                  <% if log.issue_id.present? %>
                    <%= link_to "##{log.issue_id}", issue_path(log.issue_id) %>
                  <% end %>
                </td>
                <td><%= log.pdf_filename.to_s %></td>
                <td><%= log.render_mode.to_s %></td>
                <td><%= log.quality.to_s %></td>
                <td><%= log.tool.to_s %></td>
                <td><%= log.status.to_s %></td>
                <td>
                  <% if log.status.to_s == "error" %>
                    <%= log.error_text.to_s %>
                  <% else %>
                    <% files = log.png_filenames.to_s.split("\n").reject(&:blank?) %>
                    <%= files.join(", ") %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  <% rescue StandardError %>
    <em><%= l(:label_rcpp_log_unavailable) %></em>
  <% end %>
</fieldset>
